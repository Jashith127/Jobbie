# ============================================================================
# JOBBIE ENVIRONMENT CONFIGURATION
# Copy this file to .env.local and fill in your API keys
# ============================================================================

# Database
# Default: SQLite file in prisma/dev.db
DATABASE_URL="file:./prisma/dev.db"

# ============================================================================
# Tier 1: API Sources (Primary - Free tier available)
# ============================================================================

# Adzuna Job API
# Free tier: 1,000 API calls/month
# Sign up: https://developer.adzuna.com/
ADZUNA_API_ID=""
ADZUNA_API_KEY=""

# Jooble Job API  
# Free tier: 1,000 API calls/month
# Sign up: https://jooble.org/api/about
JOOBLE_API_KEY=""

# ============================================================================
# Tier 2: Legacy Scrapers (Fallback)
# ============================================================================

# Indeed (via JSearch API - legacy, being phased out)
JSEARCH_API_KEY=""

# LinkedIn (optional, disabled by default - not recommended)
SCRAPE_LINKEDIN="false"
LINKEDIN_EMAIL=""
LINKEDIN_PASSWORD=""

# ============================================================================
# Tier 3: Niche Boards (Secondary)
# These don't require API keys - scraping works automatically
# ============================================================================
# StartupSchool, IndieHackers, Internshala (no config needed)

# ============================================================================
# Tier 4: Search Engines (Optional)
# ============================================================================

# Google Jobs (free scraping, no API key needed)
# Optional: Use Google Custom Search API for reliable access
# Free tier: 100 queries/day
# Setup: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_ENGINE_ID=""

# ============================================================================
# Search Parameters
# ============================================================================

SEARCH_KEYWORDS="developer,engineer,software"
SEARCH_LOCATION="United States"

# ============================================================================
# Job Filters
# ============================================================================

# Include keywords: at least one must match job title (empty = all accepted)
INCLUDE_KEYWORDS="developer,engineer,software"

# Exclude keywords: none should match job title (empty = nothing excluded)
EXCLUDE_KEYWORDS="senior,lead,manager"

# Preferred locations: jobs from these locations are prioritized
PREFERRED_LOCATIONS="Remote,San Francisco"

# ============================================================================
# Application
# ============================================================================

NEXT_PUBLIC_API_URL="http://localhost:3000"
