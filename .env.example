# Database
DATABASE_URL="file:./prisma/dev.db"

# Scraping
INDEED_SEARCH_KEYWORDS="senior developer,full stack,backend engineer"
INDEED_LOCATION="United States"

# LinkedIn (disabled by default - WARNING: unreliable and may break)
# Uncomment and set these to enable LinkedIn scraping
# SCRAPE_LINKEDIN=false
# LINKEDIN_EMAIL="your-email@gmail.com"
# LINKEDIN_PASSWORD="your-password"
# LINKEDIN_SEARCH_KEYWORDS="software engineer"

# Job Filters
INCLUDE_KEYWORDS="developer,engineer,software"
EXCLUDE_KEYWORDS="senior,lead,manager"
PREFERRED_LOCATIONS="San Francisco,New York,Remote"

# API
NEXT_PUBLIC_API_URL="http://localhost:3000"
