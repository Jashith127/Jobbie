# Database
DATABASE_URL="file:./prisma/dev.db"

# Job Search API
# Using JSearch API (free tier: 100 requests/month)
# Get free API key: https://rapidapi.com/apitech/api/jsearch
# Without key, demo jobs will be shown
JSEARCH_API_KEY="your-api-key-here"

# These are now used for API parameter defaults
INDEED_SEARCH_KEYWORDS="developer,engineer,software"
INDEED_LOCATION="United States"

# Job Filters
INCLUDE_KEYWORDS="developer,engineer,software"
EXCLUDE_KEYWORDS="senior,lead,manager"
PREFERRED_LOCATIONS="Remote,San Francisco"

# API
NEXT_PUBLIC_API_URL="http://localhost:3000"
