{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "app/api/**": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "env": {
    "PLAYWRIGHT_DOWNLOAD_HOST": "https://playwright.azureedge.net"
  },
  "crons": [
    {
      "path": "/api/scrape",
      "schedule": "0 0 * * *"
    }
  ]
}
